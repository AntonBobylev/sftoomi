{
    "name": "sftoomi",
    "version": "0.5.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build --configuration production",
        "dev:watch": "ng build --configuration development --watch --poll 1000",
        "dev:hot-watch": "ng serve --configuration development --host 0.0.0.0",
        "test": "ng test"
    },
    "prettier": {
        "printWidth": 100,
        "singleQuote": true,
        "overrides": [
            {
                "files": "*.html",
                "options": {
                    "parser": "angular"
                }
            }
        ]
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^21.2.2",
        "@angular/common": "^21.2.2",
        "@angular/compiler": "^21.2.2",
        "@angular/core": "^21.2.2",
        "@angular/forms": "^21.2.2",
        "@angular/platform-browser": "^21.2.2",
        "@angular/router": "^21.2.2",
        "@maskito/angular": "^5.1.1",
        "@maskito/core": "^5.1.1",
        "@maskito/kit": "^5.1.1",
        "@maskito/phone": "^5.1.1",
        "@ng-util/monaco-editor": "^21.1.0",
        "@types/luxon": "^3.7.1",
        "axios": "^1.13.6",
        "luxon": "^3.7.2",
        "ng-zorro-antd": "^21.1.1",
        "ngx-extended-pdf-viewer": "^25.6.4",
        "rxjs": "~7.8.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@angular/build": "^21.2.1",
