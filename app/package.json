        "@types/jasmine": "~6.0.0",
        "jasmine-core": "~6.1.0",
        "karma": "~6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.1",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.2.0",
        "less": "^4.5.1",
        "typescript": "~5.9.3"
    }
